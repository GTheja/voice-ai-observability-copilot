# ─── Runtime ─────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8080
LOG_LEVEL=info
API_BEARER_TOKEN=dev-local-token            # required on all /api routes

# ─── Adapter selection ───────────────────────────────────────────────────────
# mock = no external services needed; real = hit the live provider
GHL_ADAPTER=mock                            # mock | real
LLM_PROVIDER=mock                           # mock | openai | anthropic
QUEUE_DRIVER=redis                          # redis | memory
DB_DRIVER=postgres                          # postgres | memory

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
DATABASE_URL=postgres://copilot:copilot@localhost:5432/copilot
PG_POOL_MAX=10

# ─── Redis / Queue ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
ANALYSIS_QUEUE=analysis
WORKER_CONCURRENCY=4
WORKER_MAX_ATTEMPTS=5
WORKER_BACKOFF_MS=2000                       # base for exponential backoff
LLM_RATE_LIMIT_PER_MIN=120

# ─── LLM providers (only the selected one is required) ───────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
LLM_TIMEOUT_MS=30000

# ─── HighLevel (only needed when GHL_ADAPTER=real) ───────────────────────────
GHL_BASE_URL=https://services.leadconnectorhq.com
GHL_MARKETPLACE_URL=https://marketplace.gohighlevel.com
GHL_CLIENT_ID=
GHL_CLIENT_SECRET=
# Must EXACTLY match the Redirect URL configured in your GHL Marketplace app (Auth section)
GHL_REDIRECT_URI=https://your-public-host/oauth/callback
GHL_SCOPES=locations.readonly voice-ai-dashboard.readonly voice-ai-agents.readonly voice-ai-agent-goals.readonly
GHL_WEBHOOK_SECRET=
GHL_API_VERSION=2021-07-28
